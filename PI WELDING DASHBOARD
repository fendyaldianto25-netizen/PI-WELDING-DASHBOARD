                problem: document.getElementById('edit-problem').value,
                location: document.getElementById('edit-location').value,
                ok: parseInt(document.getElementById('edit-ok').value),
                ng: parseInt(document.getElementById('edit-ng').value),
                pic: document.getElementById('edit-pic').value,
                status: document.getElementById('edit-status').value,
                action: document.getElementById('edit-action').value
            };
            
            // Save to Firebase
            await saveData();
            
            // Update UI
            currentFilteredData = problemsData;
            renderTable(problemsData);
            updateKPIs(problemsData);
            updateChartsWithFilteredData(problemsData);
            updateFilterDropdowns();
            
            // Close modal
            hideEditModal();
            
            // Show success
            showNotification(`Problem "${problemsData[index].partNo}" updated successfully!`, 'success');
            
            console.log(`✅ Updated problem at index ${index}`);
        }

        async function deleteProblem(index) {
            const problem = problemsData[index];
            
            // Confirm deletion
            if (!confirm(`Are you sure you want to delete this problem?\n\nPart No: ${problem.partNo}\nPart Name: ${problem.partName}\nVendor: ${problem.vendor}`)) {
                return;
            }
            
            try {
                // Remove from array
                problemsData.splice(index, 1);
                
                // Save to Firebase
                await saveData();
                
                // Update UI
                currentFilteredData = problemsData;
                renderTable(problemsData);
                updateKPIs(problemsData);
                updateChartsWithFilteredData(problemsData);
                updateFilterDropdowns();
                
                // Show success
                showNotification(`Problem "${problem.partNo}" deleted successfully!`, 'success');
                
                console.log(`✅ Deleted problem: ${problem.partNo}`);
            } catch (error) {
                console.error('Delete error:', error);
                showNotification('Error deleting problem: ' + error.message, 'error');
            }
        }

        // ============================================
        // IMPORT EXCEL FUNCTIONS
        // ============================================
        
        let importedData = [];

        function showImportModal() {
            document.getElementById('import-modal').style.display = 'flex';
            importedData = [];
            document.getElementById('import-preview').style.display = 'none';
            document.getElementById('import-confirm-btn').style.display = 'none';
        }

        function hideImportModal() {
            document.getElementById('import-modal').style.display = 'none';
            document.getElementById('excel-file-input').value = '';
            importedData = [];
        }

        function handleExcelUpload(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, { type: 'array' });
                    
                    // Get first sheet
                    const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
                    const jsonData = XLSX.utils.sheet_to_json(firstSheet);
                    
                    console.log('Raw Excel data:', jsonData);
                    
                    if (jsonData.length === 0) {
                        showNotification('Excel file is empty!', 'error');
                        return;
                    }

                    // Process and validate data
                    importedData = processExcelData(jsonData);
                    
                    if (importedData.length === 0) {
                        showNotification('No valid data found in Excel!', 'error');
                        return;
                    }

                    // Show preview
                    showImportPreview(importedData);
                    
                } catch (error) {
                    console.error('Error reading Excel:', error);
                    showNotification('Error reading Excel file: ' + error.message, 'error');
                }
            };
            reader.readAsArrayBuffer(file);
        }

        function processExcelData(jsonData) {
            const processed = [];
            
            jsonData.forEach((row, index) => {
                try {
                    // Flexible column name matching (case-insensitive, with spaces)
                    const getColumn = (row, names) => {
                        for (let name of names) {
                            for (let key in row) {
                                if (key.toLowerCase().trim() === name.toLowerCase()) {
                                    return row[key];
                                }
                            }
                        }
                        return null;
                    };

                    // Extract data with multiple possible column names
                    const partNo = getColumn(row, ['Part No', 'PartNo', 'Part Number', 'Part_No']);
                    const partName = getColumn(row, ['Part Name', 'PartName', 'Part_Name']);
                    const vendor = getColumn(row, ['Vendor', 'Supplier']);
                    const problem = getColumn(row, ['Problem', 'Issue', 'Defect']);
                    const location = getColumn(row, ['Location', 'Lokasi']);
                    const ok = getColumn(row, ['OK', 'Ok', 'Good']);
                    const ng = getColumn(row, ['NG', 'Ng', 'Bad', 'Defect']);
                    const pic = getColumn(row, ['PIC', 'Pic', 'Person', 'Assigned']);
                    const status = getColumn(row, ['Status', 'State']);
                    const action = getColumn(row, ['Action', 'Corrective Action']);
                    let date = getColumn(row, ['Date', 'Tanggal', 'Created']);

                    // Validate required fields
                    if (!partNo || !partName || !vendor) {
                        console.warn(`Row ${index + 1} skipped: missing required fields`);
                        return;
                    }

                    // Process date
                    if (!date) {
                        date = new Date().toISOString().split('T')[0];
                    } else if (typeof date === 'number') {
                        // Excel date number to JS date
                        const excelDate = new Date((date - 25569) * 86400 * 1000);
                        date = excelDate.toISOString().split('T')[0];
                    } else if (typeof date === 'string') {
                        // Try to parse various date formats
                        const parsedDate = new Date(date);
                        if (!isNaN(parsedDate)) {
                            date = parsedDate.toISOString().split('T')[0];
                        } else {
                            date = new Date().toISOString().split('T')[0];
                        }
                    }

                    // Create problem object
                    const problemObj = {
                        date: date,
                        partNo: String(partNo).trim(),
                        partName: String(partName).trim(),
                        vendor: String(vendor || 'N/A').trim(),
                        problem: String(problem || 'N/A').trim(),
                        location: String(location || 'N/A').trim(),
                        ok: parseInt(ok) || 0,
                        ng: parseInt(ng) || 0,
                        pic: String(pic || 'N/A').trim(),
                        status: validateStatus(status),
                        action: validateAction(action)
                    };

                    processed.push(problemObj);
                } catch (error) {
                    console.error(`Error processing row ${index + 1}:`, error);
                }
            });

            return processed;
        }

        function validateStatus(status) {
            if (!status) return 'ANALISA';
            const s = String(status).toUpperCase().trim();
            if (['ANALISA', 'CONTROL', 'SELESAI'].includes(s)) {
                return s;
            }
            return 'ANALISA';
        }

        function validateAction(action) {
            if (!action) return 'REPAIR';
            const a = String(action).toUpperCase().trim();
            if (['REPAIR', 'SORTIR', 'REPLACE', 'PACS'].includes(a)) {
                return a;
            }
            return 'REPAIR';
        }

        function showImportPreview(data) {
            const previewDiv = document.getElementById('import-preview');
            const previewBody = document.getElementById('import-preview-body');
            const countSpan = document.getElementById('import-count');
            const confirmBtn = document.getElementById('import-confirm-btn');
            const btnCount = document.getElementById('import-btn-count');

            // Clear previous preview
            previewBody.innerHTML = '';

            // Show first 10 rows
            const preview = data.slice(0, 10);
            preview.forEach(item => {
                const row = document.createElement('tr');
                row.className = 'border-b hover:bg-gray-50';
                row.innerHTML = `
                    <td class="px-3 py-2">${item.partNo}</td>
                    <td class="px-3 py-2">${item.partName}</td>
                    <td class="px-3 py-2">${item.vendor}</td>
                    <td class="px-3 py-2">${item.problem}</td>
                `;
                previewBody.appendChild(row);
            });

            countSpan.textContent = data.length;
            btnCount.textContent = `(${data.length})`;
            
            previewDiv.style.display = 'block';
            confirmBtn.style.display = 'block';
        }

        async function confirmImport() {
            if (importedData.length === 0) {
                showNotification('No data to import!', 'error');
                return;
            }

            try {
                // Add all imported problems to problemsData
                problemsData.push(...importedData);
                
                // Save to Firebase
                await saveData();
                
                // Update UI
                currentFilteredData = problemsData;
                renderTable(problemsData);
                updateKPIs(problemsData);
                updateChartsWithFilteredData(problemsData);
                updateFilterDropdowns();
                
                // Close modal
                hideImportModal();
                
                // Show success
                showNotification(`Successfully imported ${importedData.length} problems!`, 'success');
                
                console.log(`✅ Imported ${importedData.length} problems from Excel`);
            } catch (error) {
                console.error('Import error:', error);
                showNotification('Error importing data: ' + error.message, 'error');
            }
        }

        // Add CSS animation for status dot
        const style = document.createElement('style');
        style.textContent = `
            @keyframes pulse {
                0%, 100% { opacity: 1; }
                50% { opacity: 0.5; }
            }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>
