        function updateChartsWithFilteredData(data) {
            const analisaCount = data.filter(d => d.status === 'ANALISA').length;
            const controlCount = data.filter(d => d.status === 'CONTROL').length;
            const selesaiCount = data.filter(d => d.status === 'SELESAI').length;
            
            if (window.statusChart) {
                window.statusChart.data.datasets[0].data = [analisaCount, controlCount, selesaiCount];
                window.statusChart.update();
            }
            
            const vendorFrequency = {};
            data.forEach(item => {
                vendorFrequency[item.vendor] = (vendorFrequency[item.vendor] || 0) + 1;
            });
            
            const sortedVendors = Object.entries(vendorFrequency)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 6);
            
            if (window.vendorChart) {
                if (sortedVendors.length > 0) {
                    window.vendorChart.data.labels = sortedVendors.map(v => v[0]);
                    window.vendorChart.data.datasets[0].data = sortedVendors.map(v => v[1]);
                } else {
                    window.vendorChart.data.labels = [];
                    window.vendorChart.data.datasets[0].data = [];
                }
                window.vendorChart.update();
            }

            const partFrequency = {};
            const partNames = {};
            data.forEach(item => {
                partFrequency[item.partNo] = (partFrequency[item.partNo] || 0) + 1;
                partNames[item.partNo] = item.partName;
            });
            
            const sortedParts = Object.entries(partFrequency)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 6);
            
            if (window.partChart) {
                if (sortedParts.length > 0) {
                    window.partChartData = sortedParts.map(p => {
                        const partNo = p[0];
                        const partName = partNames[partNo];
                        const displayName = partName.length > 12 ? partName.substring(0, 12) + '...' : partName;
                        return {
                            partNo: partNo,
                            partName: partName,
                            displayName: displayName,
                            frequency: p[1]
                        };
                    });
                    
                    window.partChart.data.labels = window.partChartData.map(p => p.partNo);
                    window.partChart.data.datasets[0].data = sortedParts.map(p => p[1]);
                } else {
                    window.partChartData = [];
                    window.partChart.data.labels = [];
                    window.partChart.data.datasets[0].data = [];
                }
                window.partChart.update();
            }
        }

