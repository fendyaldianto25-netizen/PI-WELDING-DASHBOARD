    <script>
        // ============================================
        // 🔧 PARTS MASTER DATA (loaded from JSON)
        // ============================================
        let partsMasterData = {
            parts: [],
            vendors: [],
            pics: ["ROHIM", "SIGIT", "FENDY"]
        };

        // Load parts master data from JSON file
        async function loadPartsMaster() {
            try {
                const response = await fetch('parts_master.json');
                if (response.ok) {
                    partsMasterData = await response.json();
                    console.log('✅ Parts master loaded:', {
                        parts: partsMasterData.parts.length,
                        vendors: partsMasterData.vendors.length,
                        pics: partsMasterData.pics.length
                    });
                } else {
                    console.warn('⚠️ parts_master.json not found, using default data');
                }
            } catch (error) {
                console.warn('⚠️ Could not load parts master:', error.message);
            }
        }

        // ============================================
        // 🔥 FIREBASE CONFIGURATION
        // ============================================
        const firebaseConfig = {
            apiKey: "AIzaSyD-AajNJvw7agGweRv8Py0c7x82Vo_uCog",
            authDomain: "pi-welding-dashboard.firebaseapp.com",
            databaseURL: "https://pi-welding-dashboard-default-rtdb.asia-southeast1.firebasedatabase.app",
            projectId: "pi-welding-dashboard",
            storageBucket: "pi-welding-dashboard.firebasestorage.app",
            messagingSenderId: "926901068232",
            appId: "1:926901068232:web:e4537bc599e895d8bda0fd"
        };

        // Initialize Firebase
        let database;
        let isFirebaseConfigured = false;

        function updateFirebaseStatus(connected, message) {
            const statusEl = document.getElementById('firebase-status');
            const textEl = document.getElementById('status-text');
            const dotEl = document.getElementById('status-dot');
            
            statusEl.style.display = 'flex';
            textEl.textContent = message;
            
            if (connected) {
                statusEl.className = 'firebase-status firebase-connected';
                dotEl.style.animation = 'pulse 2s infinite';
            } else {
                statusEl.className = 'firebase-status firebase-disconnected';
                dotEl.style.animation = 'none';
            }
        }

        try {
            if (firebaseConfig.apiKey !== "YOUR_API_KEY_HERE") {
                firebase.initializeApp(firebaseConfig);
                database = firebase.database();
                isFirebaseConfigured = true;
                updateFirebaseStatus(true, '🔥 Firebase Connected');
                console.log('✅ Firebase AKTIF - Data publik & realtime!');
            } else {
                updateFirebaseStatus(false, '⚠️ Firebase Not Configured');
                console.error('❌ FIREBASE BELUM DIKONFIGURASI!');
                console.log('📝 Edit firebaseConfig dengan config Anda');
                console.log('⚠️ Sementara pakai localStorage - data TIDAK sync antar device');
            }
        } catch (error) {
            updateFirebaseStatus(false, '❌ Firebase Error');
            console.error('❌ Firebase error:', error);
            isFirebaseConfigured = false;
        }

        // ============================================
        // DATA MANAGEMENT
        // ============================================
        
        const initialProblemsData = [
            { date: '2026-02-15', partNo: '14150-23K00', partName: 'PIPE EXH COMP', vendor: 'PT.TCH', problem: 'MEMBAL', location: 'LINE WELDING', ok: 10, ng: 20, pic: 'ROHIM', status: 'ANALISA', action: 'REPAIR' },
            { date: '2026-02-16', partNo: '14150-23K01', partName: 'PIPE HEAD', vendor: 'PT.WIRA', problem: 'SPATER', location: 'LINE WELDING', ok: 600, ng: 5, pic: 'FENDY', status: 'SELESAI', action: 'SORTIR' },
            { date: '2026-02-17', partNo: '14150-23K02', partName: 'TUBE CTR', vendor: 'PT.SUP', problem: 'CHAMFER', location: 'RECEIVING', ok: 120, ng: 6, pic: 'SIGIT', status: 'CONTROL', action: 'REPAIR' },
            { date: '2026-02-18', partNo: '14150-23K03', partName: 'REINF 2 ENGINE', vendor: 'PT.SUP', problem: 'KARAT', location: 'ASSY', ok: 100, ng: 4, pic: 'ROHIM', status: 'ANALISA', action: 'REPLACE' },
            { date: '2026-02-19', partNo: '14150-23K04', partName: 'TUBE REAR', vendor: 'PT.SUP', problem: 'KOTOR', location: 'PAINTING', ok: 78, ng: 23, pic: 'FENDY', status: 'SELESAI', action: 'PACS' },
            { date: '2026-02-20', partNo: '14150-23K05', partName: 'BRACKET FOOTREST', vendor: 'PT.YTK', problem: 'PENYOK', location: 'LINE WELDING', ok: 90, ng: 10, pic: 'SIGIT', status: 'CONTROL', action: 'SORTIR' },
            { date: '2026-02-21', partNo: '14150-23K06', partName: 'TUBE 11', vendor: 'PT.MKJ', problem: 'MISIING', location: 'LINE WELDING', ok: 120, ng: 11, pic: 'ROHIM', status: 'ANALISA', action: 'PACS' },
            { date: '2026-02-22', partNo: '14150-23K07', partName: 'PIPE EXH COMP', vendor: 'PT.IMMAT', problem: 'NIT TIDAK ADA', location: 'LINE WELDING', ok: 120, ng: 1, pic: 'FENDY', status: 'SELESAI', action: 'PACS' }
        ];

        let problemsData = [...initialProblemsData];
        let darkMode = false;
        let currentFilteredData = problemsData;

        // Load data
        async function loadData() {
            if (isFirebaseConfigured) {
                return new Promise((resolve) => {
                    const dbRef = database.ref('weldingProblems');
                    dbRef.once('value', (snapshot) => {
                        const data = snapshot.val();
                        if (data && Array.isArray(data)) {
                            console.log('🔥 Loaded', data.length, 'from Firebase - SHARED DATA');
                            resolve(data);
                        } else {
                            console.log('📦 Init Firebase dengan data awal');
                            dbRef.set(initialProblemsData);
                            resolve([...initialProblemsData]);
                        }
                    }, (error) => {
                        console.error('Firebase read error:', error);
                        resolve([...initialProblemsData]);
                    });
                });
            } else {
                const saved = localStorage.getItem('weldingProblemsData');
                if (saved) {
                    const parsed = JSON.parse(saved);
                    console.log('💾 Loaded from localStorage - LOCAL ONLY');
                    return parsed;
                }
                return [...initialProblemsData];
            }
        }

        // Save data
        async function saveData() {
            if (isFirebaseConfigured) {
                try {
                    await database.ref('weldingProblems').set(problemsData);
                    console.log('🔥 Saved to Firebase - ALL DEVICES UPDATE!');
                    updateFirebaseStatus(true, '✅ Data Saved to Cloud');
                    setTimeout(() => {
                        updateFirebaseStatus(true, '🔥 Firebase Connected');
                    }, 2000);
                } catch (error) {
                    console.error('Firebase save error:', error);
                    localStorage.setItem('weldingProblemsData', JSON.stringify(problemsData));
                }
            } else {
                localStorage.setItem('weldingProblemsData', JSON.stringify(problemsData));
                console.log('💾 Saved locally - NOT synced');
            }
        }

        // Realtime listener
        function startRealtimeSync() {
            if (isFirebaseConfigured) {
                console.log('🔄 Starting realtime sync...');
                const dbRef = database.ref('weldingProblems');
                
                dbRef.on('value', (snapshot) => {
                    const data = snapshot.val();
                    if (data && Array.isArray(data)) {
                        problemsData = data;
                        currentFilteredData = problemsData;
                        
                        renderTable(problemsData);
                        updateKPIs(problemsData);
                        updateChartsWithFilteredData(problemsData);
                        updateFilterDropdowns();
                        
                        console.log('🔄 REALTIME UPDATE:', problemsData.length, 'problems');
                    }
                }, (error) => {
                    console.error('Realtime listener error:', error);
                });
            }
        }

        // Initialize
        window.onload = async function() {
            // Load parts master data first
            await loadPartsMaster();
            
            // Then load problem data
            problemsData = await loadData();
            currentFilteredData = problemsData;
            
            renderTable(problemsData);
            updateKPIs(problemsData);
            createCharts();
            
            document.getElementById('month-filter').value = 'ALL';
            console.log('📊 Dashboard loaded:', problemsData.length, 'problems');
            
            // Populate datalists for autocomplete
            populateDataLists();
            
            startRealtimeSync();
        };

        // ============================================
        // AUTOCOMPLETE FUNCTIONS
        // ============================================
        
        function populateDataLists() {
            // Part No list
            const partnoList = document.getElementById('partno-list');
            partsMasterData.parts.forEach(part => {
                const option = document.createElement('option');
                option.value = part.partNo;
                partnoList.appendChild(option);
            });

            // Part Name list
            const partnameList = document.getElementById('partname-list');
            partsMasterData.parts.forEach(part => {
                const option = document.createElement('option');
                option.value = part.partName;
                partnameList.appendChild(option);
            });

            // Vendor list
            const vendorList = document.getElementById('vendor-list');
            partsMasterData.vendors.forEach(vendor => {
                const option = document.createElement('option');
                option.value = vendor;
                vendorList.appendChild(option);
            });

            // PIC list
            const picList = document.getElementById('pic-list');
            partsMasterData.pics.forEach(pic => {
                const option = document.createElement('option');
                option.value = pic;
                picList.appendChild(option);
            });

            console.log('✅ Datalists populated:', {
                parts: partsMasterData.parts.length,
                vendors: partsMasterData.vendors.length,
                pics: partsMasterData.pics.length
            });
        }

        // Auto-fill Part Name and Vendor when Part No is selected (Add Modal)
        function autoFillPartData(partNo) {
            const part = partsMasterData.parts.find(p => p.partNo === partNo);
            if (part) {
                document.getElementById('input-partname').value = part.partName;
                document.getElementById('input-vendor').value = part.vendor;
                document.getElementById('input-pic').value = part.pic;
                console.log('✅ Auto-filled:', part.partNo, '→', part.partName);
            }
        }

        // Auto-fill Part Name and Vendor when Part No is selected (Edit Modal)
        function autoFillPartDataEdit(partNo) {
            const part = partsMasterData.parts.find(p => p.partNo === partNo);
            if (part) {
                document.getElementById('edit-partname').value = part.partName;
                document.getElementById('edit-vendor').value = part.vendor;
                document.getElementById('edit-pic').value = part.pic;
                console.log('✅ Auto-filled (edit):', part.partNo, '→', part.partName);
            }
        }

        // [REST OF THE JAVASCRIPT CODE - Dark Mode, Render Table, KPIs, Charts, Modals, Export functions]
        // Continuing the script with the complete dashboard functionality...
        
        function toggleDarkMode() {
            darkMode = !darkMode;
            const body = document.getElementById('body');
            const moonIcon = document.getElementById('moon-icon');
            const sunIcon = document.getElementById('sun-icon');
            
            if (darkMode) {
                body.classList.remove('light-mode');
                body.classList.add('dark-mode');
                document.getElementById('main-container').style.color = '#f9fafb';
                moonIcon.style.display = 'none';
                sunIcon.style.display = 'block';
                applyDarkModeStyles();
            } else {
                body.classList.remove('dark-mode');
                body.classList.add('light-mode');
                document.getElementById('main-container').style.color = '#111827';
                moonIcon.style.display = 'block';
                sunIcon.style.display = 'none';
                removeDarkModeStyles();
            }
        }

        function applyDarkModeStyles() {
            const cards = ['header-card', 'kpi-problems', 'kpi-defect', 'kpi-ok', 'kpi-ng', 'filters-card', 'status-chart-card', 'vendor-chart-card', 'part-chart-card', 'table-card', 'modal-content'];
            cards.forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.style.backgroundColor = '#1f2937';
                    el.style.color = '#f9fafb';
                }
            });
            
            document.getElementById('main-title').style.color = '#f9fafb';
            document.getElementById('subtitle').style.color = '#9ca3af';
            
            const inputs = document.querySelectorAll('input, select');
            inputs.forEach(input => {
                input.style.backgroundColor = '#374151';
                input.style.borderColor = '#4b5563';
                input.style.color = '#f9fafb';
            });
            
            document.getElementById('table-header').style.backgroundColor = '#374151';
            document.getElementById('table-body').style.backgroundColor = '#1f2937';
        }

        function removeDarkModeStyles() {
            const cards = ['header-card', 'kpi-problems', 'kpi-defect', 'kpi-ok', 'kpi-ng', 'filters-card', 'status-chart-card', 'vendor-chart-card', 'part-chart-card', 'table-card', 'modal-content'];
            cards.forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.style.backgroundColor = '#ffffff';
                    el.style.color = '#111827';
                }
            });
            
            document.getElementById('main-title').style.color = '#111827';
            document.getElementById('subtitle').style.color = '#6b7280';
            
            const inputs = document.querySelectorAll('input, select');
            inputs.forEach(input => {
                input.style.backgroundColor = '#ffffff';
                input.style.borderColor = '#d1d5db';
                input.style.color = '#111827';
            });
            
            document.getElementById('table-header').style.backgroundColor = '#f9fafb';
            document.getElementById('table-body').style.backgroundColor = '#ffffff';
        }

        function renderTable(data) {
            const tbody = document.getElementById('table-body');
            tbody.innerHTML = '';
            
            const sortedData = [...data].sort((a, b) => new Date(b.date) - new Date(a.date));
            
            sortedData.forEach((item, index) => {
                // Find original index in problemsData
                const originalIndex = problemsData.findIndex(p => 
                    p.date === item.date && 
                    p.partNo === item.partNo && 
                    p.vendor === item.vendor &&
                    p.problem === item.problem
                );
                
                const row = document.createElement('tr');
                row.className = 'hover:bg-gray-50 transition-colors';
                row.innerHTML = `
                    <td class="px-6 py-4 whitespace-nowrap text-sm">${new Date(item.date).toLocaleDateString('id-ID')}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">${item.partNo}</td>
                    <td class="px-6 py-4 text-sm">${item.partName}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">${item.vendor}</td>
                    <td class="px-6 py-4 text-sm">${item.problem}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">${item.location}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                        <span class="text-green-600 font-semibold">${item.ok}</span> / 
                        <span class="text-red-600 font-semibold">${item.ng}</span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">${getPriorityBadge(item.ng, item.ok + item.ng)}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">${item.pic}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">${getStatusBadge(item.status)}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">${item.action}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                        <div class="flex gap-2">
                            <button onclick="editProblem(${originalIndex})" class="text-blue-600 hover:text-blue-800 p-1" title="Edit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                </svg>
                            </button>
                            <button onclick="deleteProblem(${originalIndex})" class="text-red-600 hover:text-red-800 p-1" title="Delete">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                    <line x1="10" y1="11" x2="10" y2="17"></line>
                                    <line x1="14" y1="11" x2="14" y2="17"></line>
                                </svg>
                            </button>
                        </div>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        function getPriorityBadge(ng, total) {
            const rate = (ng / total) * 100;
            if (rate > 15) return '<span class="priority-badge" style="background-color: #ef4444;">HIGH</span>';
            if (rate > 5) return '<span class="priority-badge" style="background-color: #f59e0b;">MED</span>';
            return '<span class="priority-badge" style="background-color: #10b981;">LOW</span>';
        }

        function getStatusColor(status) {
            const colors = {
                'SELESAI': 'bg-green-100 text-green-800',
                'ANALISA': 'bg-red-100 text-red-800',
                'CONTROL': 'bg-yellow-100 text-yellow-800'
            };
            return colors[status] || 'bg-gray-100 text-gray-800';
        }

        function getStatusBadge(status) {
            const colors = {
                'SELESAI': 'background-color: #d1fae5; color: #065f46;',
                'ANALISA': 'background-color: #fee2e2; color: #991b1b;',
                'CONTROL': 'background-color: #fef3c7; color: #92400e;'
            };
            return `<span class="status-badge" style="${colors[status]}">${status}</span>`;
        }

        function updateKPIs(data) {
            const totalOK = data.reduce((sum, item) => sum + item.ok, 0);
            const totalNG = data.reduce((sum, item) => sum + item.ng, 0);
            const defectRate = totalOK + totalNG > 0 ? ((totalNG / (totalOK + totalNG)) * 100).toFixed(2) : '0.00';
            
            document.getElementById('total-problems').textContent = data.length;
            document.getElementById('defect-rate').textContent = defectRate + '%';
            
            if (data.length > 0) {
                const vendorFrequency = {};
                data.forEach(item => {
                    vendorFrequency[item.vendor] = (vendorFrequency[item.vendor] || 0) + 1;
                });
                
                const worstVendor = Object.entries(vendorFrequency)
                    .sort((a, b) => b[1] - a[1])[0];
                
                document.getElementById('worst-vendor').textContent = worstVendor[0];
                document.getElementById('worst-vendor-count').textContent = `${worstVendor[1]} problem${worstVendor[1] > 1 ? 's' : ''}`;
            } else {
                document.getElementById('worst-vendor').textContent = '-';
                document.getElementById('worst-vendor-count').textContent = 'No data';
            }
            
            const pacsCount = data.filter(item => item.action === 'PACS').length;
            document.getElementById('total-pacs').textContent = pacsCount;
        }

        function filterTable() {
            const search = document.getElementById('search-input').value.toLowerCase();
            const monthFilter = document.getElementById('month-filter').value;
            const statusFilter = document.getElementById('status-filter').value;
            const vendorFilter = document.getElementById('vendor-filter').value;
            const picFilter = document.getElementById('pic-filter').value;
            
            let filtered = problemsData.filter(item => {
                const matchSearch = item.partNo.toLowerCase().includes(search) || 
                                  item.partName.toLowerCase().includes(search) ||
                                  item.problem.toLowerCase().includes(search);
                
                const itemMonth = new Date(item.date).getMonth() + 1;
                const itemMonthStr = itemMonth.toString().padStart(2, '0');
                const matchMonth = monthFilter === 'ALL' || itemMonthStr === monthFilter;
                
                const matchStatus = statusFilter === 'ALL' || item.status === statusFilter;
                const matchVendor = vendorFilter === 'ALL' || item.vendor === vendorFilter;
                const matchPIC = picFilter === 'ALL' || item.pic === picFilter;
                
                return matchSearch && matchMonth && matchStatus && matchVendor && matchPIC;
            });
            
            currentFilteredData = filtered;
            renderTable(filtered);
            updateKPIs(filtered);
            updateChartsWithFilteredData(filtered);
        }

